{
  "hooks": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "python -m py_compile \"$CLAUDE_FILE_PATHS\" && echo 'Syntax OK'"
        },
        {
          "type": "command",
          "command": "python core/validate_config.py 2>/dev/null || echo 'Config check skipped'"
        }
      ]
    }
  ]
}
